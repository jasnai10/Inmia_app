<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_login_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="800dp"
        android:paddingHorizontal="28dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <!-- Logo / Ícono superior -->
        <ImageView
            android:id="@+id/imgLoginLogo"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_logo_inmia"
            android:contentDescription="Logo INMIA"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Nombre de la app -->
        <TextView
            android:id="@+id/tvAppNameLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INMIA"
            android:textColor="@color/inmia_text"
            android:textSize="22sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.25"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/imgLoginLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Título de bienvenida -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bienvenido de nuevo"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/inmia_text"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvAppNameLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Subtítulo -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inicia sesión en tu cuenta inmia"
            android:textSize="14sp"
            android:textColor="#7A9E9E"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvWelcome"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ─── CARD PRINCIPAL ─── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLogin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Campo: Correo electrónico -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Correo electrónico"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="@color/inmia_teal_dark"
                    app:boxStrokeColor="@color/inmia_teal_dark"
                    app:hintTextColor="@color/inmia_teal_dark"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo: Contraseña -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Contraseña"
                    app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                    app:startIconTint="@color/inmia_teal_dark"
                    app:boxStrokeColor="@color/inmia_teal_dark"
                    app:hintTextColor="@color/inmia_teal_dark"
                    app:passwordToggleEnabled="true"
                    app:passwordToggleTint="@color/inmia_teal_dark"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"/>

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ¿Olvidaste tu contraseña? -->
                <TextView
                    android:id="@+id/tvForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="10dp"
                    android:text="¿Olvidaste tu contraseña?"
                    android:textColor="@color/inmia_teal_dark"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- Botón Iniciar Sesión -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:text="Iniciar sesión"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:textColor="@color/inmia_white"
                    app:backgroundTint="@color/inmia_teal_dark"
                    app:cornerRadius="14dp"
                    app:elevation="4dp"/>

                <!-- Divider con "o" -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E0EEEE"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  o  "
                        android:textColor="#A0BFBF"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E0EEEE"/>
                </LinearLayout>

                <!-- Botón Crear Cuenta (outlined) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:text="Crear una cuenta"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:textColor="@color/inmia_teal_dark"
                    app:strokeColor="@color/inmia_teal_dark"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="14dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Footer: texto de términos -->
        <TextView
            android:id="@+id/tvTerms"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Al continuar, aceptas nuestros Términos de Uso y Política de Privacidad."
            android:textColor="#A0BFBF"
            android:textSize="12sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3"
            app:layout_constraintTop_toBottomOf="@id/cardLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>