<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema base de la app -->
    <style name="Theme.Inmia" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/inmia_teal_dark</item>
        <item name="colorPrimaryVariant">@color/inmia_teal_light</item>
        <item name="colorOnPrimary">@color/inmia_white</item>
        <item name="android:statusBarColor">@color/inmia_teal_dark</item>
    </style>

    <!-- Tema para el Splash (sin ActionBar) -->
    <style name="Theme.Inmia.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@color/inmia_teal_dark</item>
    </style>

</resources>